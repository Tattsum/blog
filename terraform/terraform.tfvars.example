# コピーして terraform.tfvars を作成し、実際の値に書き換えてください。
# terraform.tfvars は .gitignore に追加することを推奨します。

project_id = "your-gcp-project-id"
region     = "asia-northeast1"

# Cloud SQL（省略時はデフォルト値）
# db_tier = "db-f1-micro"
# db_name = "blog"

# 本番では必ず設定すること。未設定時は Terraform がランダム生成（state に平文が残る）
# db_root_password = "your-secure-root-password"

# 管理 API キー（必須）
admin_api_key = "your-secure-admin-api-key"

# Cloud Run サービス名（既定 blog-backend。既存 blog-api を Terraform 管理する場合のみ上書き）
# cloud_run_service_name = "blog-backend"

# 初回 apply 前にイメージをビルド・push しておく
# 例: docker build -t asia-northeast1-docker.pkg.dev/PROJECT_ID/blog-repo/blog-api:latest -f ../backend/Dockerfile ..
#      docker push ...
# イメージ名 blog-api は Artifact Registry のリポジトリ名。Cloud Run サービス名とは別。
cloud_run_image = "asia-northeast1-docker.pkg.dev/your-gcp-project-id/blog-repo/blog-api:latest"

# --- メディアストレージ（省略時はローカル＝Cloud Run では非永続。本番では gcs または r2 を推奨）---
# docs/setup-deploy-checklist.md の「6.6 メディアアップロードを GCS または R2 で永続化する」を参照。
# media_storage = "gcs"
# gcs_media_bucket = "blog-media"   # 事前にバケット作成・公開読取設定が必要
# gcs_public_base_url = "https://asset.example.com"  # 省略時は storage.googleapis.com/bucket 形式。LB+カスタムドメインで配信するときのみ指定

# R2 を使う場合（機密は tfvars に記載せず CI の Secret 等で渡す運用も可）
# media_storage = "r2"
# r2_account_id = "your-cloudflare-account-id"
# r2_access_key_id = "your-r2-access-key-id"
# r2_secret_access_key = "your-r2-secret-access-key"
# r2_bucket = "blog-media"
# r2_public_base_url = "https://pub-xxxx.r2.dev"

# --- Vertex AI Gemini モデル ---
# デフォルト（gemini-1.5-flash-002）で問題ない場合は省略可。
# gemini-2.0-flash-001 など別モデルを使いたい場合に上書きする。
# vertex_gemini_model = "gemini-1.5-flash-002"

# --- AI（Vertex 経由で統一）---
# Claude を優先して使う（推奨: 運用統一したい場合）
# ai_provider = "claude"  # または "vertex-claude"
# vertex_claude_model = "claude-sonnet-4-6"   # Model Garden の publishers/anthropic/models を参照
#
# Gemini を使う（デフォルト）。モデルは Model Garden の publishers/google/models にある ID を指定
# vertex_gemini_model = "gemini-2.5-flash"
